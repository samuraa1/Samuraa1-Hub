		end

		for _, label in ipairs(ChangelogScroll:GetChildren()) do
			if label:IsA("TextLabel") then
				label.TextTransparency = 1
				TweenService:Create(label, TweenInfo.new(0.4, Enum.EasingStyle.Quint), { TextTransparency = 0 }):Play()
				task.wait(0.015)
			end
		end
	end

	local function hideDialog()
		TweenService:Create(ChangelogDialog, TweenInfo.new(0.42, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {
			Size = UDim2.new(0, 0, 0, 0),
			BackgroundTransparency = 1,
		}):Play()
		TweenService:Create(DialogShadow, TweenInfo.new(0.42, Enum.EasingStyle.Quint), { ImageTransparency = 1 }):Play()
		TweenService:Create(DialogTitle, TweenInfo.new(0.4, Enum.EasingStyle.Quint), { TextTransparency = 1 }):Play()
		TweenService:Create(TopAccent, TweenInfo.new(0.35, Enum.EasingStyle.Quint), { BackgroundTransparency = 1 }):Play()
		TweenService:Create(CloseButton, TweenInfo.new(0.4, Enum.EasingStyle.Quint), { TextTransparency = 1, BackgroundTransparency = 1 }):Play()
		TweenService:Create(CloseStroke, TweenInfo.new(0.4, Enum.EasingStyle.Quint), { Transparency = 1 }):Play()
		TweenService:Create(AltButton, TweenInfo.new(0.4, Enum.EasingStyle.Quint), { TextTransparency = 1, BackgroundTransparency = 1 }):Play()
		TweenService:Create(AltStroke, TweenInfo.new(0.4, Enum.EasingStyle.Quint), { Transparency = 1 }):Play()

		if showSearchBar then
			TweenService:Create(SearchBar, TweenInfo.new(0.4, Enum.EasingStyle.Quint), { BackgroundTransparency = 1 }):Play()
			TweenService:Create(SearchStroke, TweenInfo.new(0.4, Enum.EasingStyle.Quint), { Transparency = 1 }):Play()
			TweenService:Create(SearchIcon, TweenInfo.new(0.4, Enum.EasingStyle.Quint), { ImageTransparency = 1 }):Play()
			TweenService:Create(SearchInput, TweenInfo.new(0.4, Enum.EasingStyle.Quint), { TextTransparency = 1 }):Play()
		end

		for _, label in ipairs(ChangelogScroll:GetChildren()) do
			if label:IsA("TextLabel") then
				TweenService:Create(label, TweenInfo.new(0.38, Enum.EasingStyle.Quint), { TextTransparency = 1 }):Play()
			end
		end

		task.wait(0.45)
		Main:Destroy()

		if notificationsEnabled then
			self:Notify(notification)
		end
	end

	CloseButton.MouseButton1Click:Connect(hideDialog)

	local dragging, dragInput, dragStart, startPos
	local function update(input)
		local delta = input.Position - dragStart
		ChangelogDialog.Position = UDim2.new(
			startPos.X.Scale,
			startPos.X.Offset + delta.X,
			startPos.Y.Scale,
			startPos.Y.Offset + delta.Y
		)
	end

	ChangelogDialog.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			dragStart = input.Position
			startPos = ChangelogDialog.Position
			input.Changed:Connect(function()
				if input.UserInputState == Enum.UserInputState.End then
					dragging = false
				end
			end)
		end
	end)

	ChangelogDialog.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
			dragInput = input
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if input == dragInput and dragging then
			update(input)
		end
	end)

	showDialog()

	return {
		Hide = hideDialog,
		Show = showDialog,
	}
end

return SearchAndChangelogLibrary
