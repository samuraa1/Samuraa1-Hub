function MentalityNotif:Notify(data, notifFrame, template, layout)
	task.spawn(function()
		local newNotification = template:Clone()
		newNotification.Name = data.Title or "Notice"
		newNotification.Parent = notifFrame
		newNotification.LayoutOrder = #notifFrame:GetChildren()
		newNotification.Visible = false

		newNotification.Title.Text = data.Title or "Notice"
		newNotification.Description.Text = data.Content or ""

		if data.Image then
			newNotification.Icon.Image = getAssetUri(data.Image)
		else
			newNotification.Icon.Image = "rbxassetid://0"
		end

		newNotification.BackgroundTransparency = 1
		newNotification.Title.TextTransparency = 1
		newNotification.Description.TextTransparency = 1
		newNotification.UIStroke.Transparency = 1
		newNotification.Icon.ImageTransparency = 1

		task.wait()

		newNotification.Visible = true

		local boundsY = newNotification.Title.TextBounds.Y + newNotification.Description.TextBounds.Y
		local h = math.max(boundsY + 24, 56)

		newNotification.Icon.Size = UDim2.new(0, 28, 0, 28)
		newNotification.Icon.Position = UDim2.new(0, 12, 0.5, 0)

		TweenService:Create(newNotification, TweenInfo.new(0.45, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
			Size = UDim2.new(1, 0, 0, h),
		}):Play()

		task.wait(0.08)
		TweenService:Create(newNotification, TweenInfo.new(0.25, Enum.EasingStyle.Quint), { BackgroundTransparency = 0.12 }):Play()
		TweenService:Create(newNotification.Title, TweenInfo.new(0.22, Enum.EasingStyle.Quint), { TextTransparency = 0 }):Play()
		TweenService:Create(newNotification.UIStroke, TweenInfo.new(0.28, Enum.EasingStyle.Quint), { Transparency = 0.35 }):Play()
		task.wait(0.04)
		TweenService:Create(newNotification.Icon, TweenInfo.new(0.22, Enum.EasingStyle.Quint), { ImageTransparency = 0 }):Play()
		task.wait(0.04)
		TweenService:Create(newNotification.Description, TweenInfo.new(0.22, Enum.EasingStyle.Quint), { TextTransparency = 0.1 }):Play()

		local waitDuration = math.clamp((#newNotification.Description.Text * 0.08) + 2.2, 2.5, 12)
		task.wait(data.Duration or waitDuration)

		TweenService:Create(newNotification, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.In), { BackgroundTransparency = 1 }):Play()
		TweenService:Create(newNotification.UIStroke, TweenInfo.new(0.3, Enum.EasingStyle.Quint), { Transparency = 1 }):Play()
		TweenService:Create(newNotification.Title, TweenInfo.new(0.25, Enum.EasingStyle.Quint), { TextTransparency = 1 }):Play()
		TweenService:Create(newNotification.Description, TweenInfo.new(0.25, Enum.EasingStyle.Quint), { TextTransparency = 1 }):Play()
		TweenService:Create(newNotification.Icon, TweenInfo.new(0.25, Enum.EasingStyle.Quint), { ImageTransparency = 1 }):Play()

		task.wait(0.35)
		newNotification:Destroy()
	end)
end

function SearchAndChangelogLibrary:Notify(data)
	if self.MentalityNotifFrame then
		MentalityNotif:Notify(data, self.MentalityNotifFrame, self.MentalityTemplate, self.MentalityLayout)
	end
end

